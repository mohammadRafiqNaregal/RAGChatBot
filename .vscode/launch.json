{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: Debug (fastapi-clean)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/fastapi-clean/.venv/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/fastapi-clean",
      "args": ["main:app", "--host", "127.0.0.1", "--port", "8000"],
      "justMyCode": true,
      "console": "integratedTerminal"
    },
    {
      "name": "FastAPI: Dev Reload (fastapi-clean)",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/fastapi-clean/.venv/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/fastapi-clean",
      "args": ["main:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "justMyCode": true,
      "console": "integratedTerminal"
    }
  ]
}
